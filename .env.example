# Tùy chọn: Tài khoản Gmail dùng để gửi mail.
# Nếu để trống, bot sẽ dùng MAIL_TO làm tài khoản đăng nhập Gmail.
GMAIL_USER=your_email@gmail.com

# Gmail App Password (16 ký tự) tạo sau khi bật 2FA
GMAIL_APP_PASSWORD=your_app_password

# Email người nhận
MAIL_TO=namkimu46@gmail.com

# Tùy chọn
MAIL_SUBJECT=Bản tin giá xăng dầu, công nghệ, tài chính và sức khỏe
MAIL_TIMEZONE=Asia/Ho_Chi_Minh
MAIL_MAX_RETRIES=2
MAIL_RECENT_HOURS=24
DRY_RUN=false
